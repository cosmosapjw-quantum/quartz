+            drift_radius=0.01,
+            bias_radius=0.01,
+            lower=0.32,
+            upper=0.48,
+        ),
+        EdgeObservation(
+            edge_pos=1,
+            action_id=481,
+            visible=True,
+            prior_anchor=0.3,
+            prior_current=0.3,
+            visits=8,
+            virtual_visits=1,
+            pending=1,
+            q_mean=0.2,
+            q_sum=1.6,
+            m2=0.6,
+            mc_radius=0.08,
+            epistemic_radius=0.03,
+            drift_radius=0.02,
+            bias_radius=0.01,
+            lower=0.06,
+            upper=0.34,
+        ),
+        EdgeObservation(
+            edge_pos=2,
+            action_id=999,
+            visible=False,
+            prior_anchor=0.1,
+            prior_current=0.1,
+            visits=0,
+            virtual_visits=0,
+            pending=0,
+            q_mean=0.0,
+            q_sum=0.0,
+            m2=0.0,
+            mc_radius=0.2,
+            epistemic_radius=0.1,
+            drift_radius=0.0,
+            bias_radius=0.05,
+            lower=-0.35,
+            upper=0.35,
+        ),
+    )
+    return RootObservation(
+        root_hash=123,
+        checkpoint_id="seed_1/gen_1",
+        position_id="p1",
+        game="gomoku7",
+        root_visits=24,
+        iteration=25,
+        elapsed_ms=12,
