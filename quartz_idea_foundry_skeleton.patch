+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+REGISTRY = REPO_ROOT / "configs" / "idea_foundry.axes.v1.json"
+
+
+def observation() -> RootObservation:
+    edges = (
+        EdgeObservation(
+            edge_pos=0,
+            action_id=10,
