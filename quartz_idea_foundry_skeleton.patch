+fn best_q_and_lower(observation: &FoundryObservation<'_>) -> Option<(f32, f32)> {
+    observation
+        .edges
+        .iter()
+        .max_by(|a, b| a.q.total_cmp(&b.q))
+        .map(|edge| (edge.q, edge.q - edge.sigma_a(4.0)))
